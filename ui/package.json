{
  "name": "racenet-ui",
  "version": "0.1.0",
  "description": "Overcut \u2014 Electron/React display layer",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run vite\" \"wait-on http://localhost:5173 && npm run electron:dev\"",
    "vite": "vite",
    "browser": "vite",
    "electron:dev": "cross-env ELECTRON_DEV=1 electron .",
    "build": "vite build",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@fontsource/rajdhani": "^5.0.0",
    "@fontsource/space-grotesk": "^5.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "postcss": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  }
}